# ============================================================
# БАЗА
# ============================================================
# Ключ от ProxyAPI (получить на https://console.proxyapi.ru/keys)
PROXYAPI_KEY=sk-ваш-ключ-здесь
# Опционально: включить провайдер Veo
# ENABLE_VEO_PROVIDER=1
# Опционально: включить Veo referenceImages (до 3 изображений)
# ENABLE_VEO_REFERENCE_IMAGES=1

# Токен Telegram-бота (нужен для main.py и telegram_bot.py)
TELEGRAM_BOT_TOKEN=1234567890:your-bot-token
# Таймаут HTTP к api.telegram.org (сек), ретраи sendMessage/getUpdates при обрывах сети
# TELEGRAM_HTTP_TIMEOUT=45
# При старте бот снимает webhook; при необходимости сбросить очередь апдейтов:
# TELEGRAM_DROP_PENDING_ON_WEBHOOK_DELETE=1

# ============================================================
# РЕЖИМ 1: main.py (CLI + Telegram уведомления)
# ============================================================
# Для main.py можно указать target chat напрямую.
# Если не указывать, main.py попробует взять TELEGRAM_ALLOWED_CHAT_ID.
TELEGRAM_CHAT_ID=123456789

# ============================================================
# РЕЖИМ 2: telegram_bot.py (чат-бот)
# ============================================================
# Если указать, бот будет принимать команды только от этого chat_id.
TELEGRAM_ALLOWED_CHAT_ID=123456789

# Админы для команд управления кредитами (через запятую)
# Если не задано, и TELEGRAM_ALLOWED_CHAT_ID указан, он используется как админ.
TELEGRAM_ADMIN_CHAT_IDS=123456789

# Параметры по умолчанию
DEFAULT_MODEL=sora-2
DEFAULT_SECONDS=4
DEFAULT_SIZE=1280x720
POLL_INTERVAL=3

# Таймаут загрузки видео в Telegram (сек)
TELEGRAM_UPLOAD_TIMEOUT=600
# Режим отправки в Telegram: video | document | auto
# document обычно отправляется быстрее, но без inline-плеера как у sendVideo.
TELEGRAM_UPLOAD_MODE=auto
# Для режима auto: если размер >= порога, отправляем как document.
TELEGRAM_UPLOAD_DOCUMENT_THRESHOLD_MB=8

# Оценка стоимости (руб/сек), если недоступен метод баланса
SORA2_PRICE_PER_SECOND_RUB=20
SORA2_PRO_PRICE_PER_SECOND_RUB=30
VEO31_PRICE_PER_SECOND_RUB=95

# Кредитная система telegram_bot.py
DEFAULT_NEW_CHAT_CREDITS=20
# Единая БД биллинга (общая для bot + web)
BILLING_DB_PATH=billing.db
# Старое имя переменной поддерживается как fallback:
# CREDITS_DB_PATH=credits_db.json

# ============================================================
# РЕЖИМ 3: app.py (Flask веб)
# ============================================================
# Токен доступа к мини-админке /admin
WEB_ADMIN_TOKEN=change-me-admin-token

# ============================================================
# РЕЖИМ 4: ПЛАТЕЖИ T-БАНК (опционально)
# ============================================================
# Без этих переменных /payments/create будет отключен.
TBANK_TERMINAL_KEY=your-terminal-key
TBANK_PASSWORD=your-terminal-password
# Локальный тестовый режим оплаты без T-Bank:
# APP_ENV=dev
# MOCK_PAYMENTS_ENABLED=1
# Базовый URL Flask-приложения, нужен для mock payment links (web/bot)
# APP_BASE_URL=http://127.0.0.1:5000
# Опционально: отдельный токен защиты для /mock-pay/*
# MOCK_PAYMENTS_TOKEN=local-mock-token
# По умолчанию: https://securepay.tinkoff.ru/v2
# TBANK_API_URL=https://securepay.tinkoff.ru/v2
# Необязательно: URL для редиректа после оплаты
# TBANK_SUCCESS_URL=https://your-domain/payment/success
# TBANK_FAIL_URL=https://your-domain/payment/fail
# Необязательно: webhook URL
# TBANK_NOTIFICATION_URL=https://your-domain/payments/webhook/tbank
# Необязательно: кастомные пакеты кредитов (JSON-массив)
# PAYMENT_PACKAGES_JSON=[{"id":"p5","rub":100,"credits":5,"title":"Старт 5"}]

# Авто-очистка старых web-задач:
# удаляются completed/failed задачи старше WEB_TASK_RETENTION_HOURS
WEB_TASK_RETENTION_HOURS=168
WEB_CLEANUP_INTERVAL_SECONDS=600

# Необязательно: можно переопределить пути хранения web-данных
# WEB_TASKS_DB_PATH=web_tasks.db
# WEB_OUTPUT_DIR=web_videos
